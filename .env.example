# Environment mode: dev (PGlite local file) | prod (PostgreSQL)
ENV=dev

# Database — required when ENV=prod, ignored when ENV=dev
# DATABASE_URL=postgresql://user:password@localhost:5432/myapp

# Better Auth
BETTER_AUTH_SECRET=dev-secret-at-least-32-chars-long-for-local-development-only
BETTER_AUTH_URL=http://localhost:4001

# Frontend origin (for CORS and Better Auth trusted origins)
FRONTEND_URL=http://localhost:4000

# AI - compatible with any OpenAI-format provider
# OpenAI: https://api.openai.com/v1
# DeepSeek: https://api.deepseek.com/v1
# Ollama: http://localhost:11434/v1
AI_API_KEY=your-api-key-here
AI_BASE_URL=https://api.openai.com/v1
AI_MODEL=gpt-4o-mini

# S3-compatible storage (MinIO for local dev, AWS S3 / Cloudflare R2 / Aliyun OSS for prod)
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=uploads
